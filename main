<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>오늘의 운세</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding: 50px; }
        #result { margin-top: 20px; font-size: 1.5em; font-weight: bold; color: #2c3e50; }
        button { padding: 10px 20px; font-size: 1em; cursor: pointer; }
    </style>
</head>
<body>
    <h1>🔮 오늘의 운세</h1>
    <button onclick="getFortune()">운세 확인하기</button>
    <div id="result"></div>

    <script>
        const fortunes = [
            "오늘은 모든 일이 술술 풀리는 최고의 날입니다!",
            "생각지 못한 행운이 찾아올 수 있으니 주변을 잘 살펴보세요.",
            "신중한 선택이 필요한 날입니다. 서두르지 마세요.",
            "주변 사람들과의 소통에서 기쁨을 찾을 수 있습니다.",
            "지출이 생길 수 있으니 계획적인 소비를 권장합니다.",
            "휴식이 필요한 때입니다. 오늘은 일찍 귀가해 보세요."
        ];
        function getFortune() {
            const random = Math.floor(Math.random() * fortunes.length);
            document.getElementById('result').innerText = fortunes[random];
        }
    </script>
</body>
</html>